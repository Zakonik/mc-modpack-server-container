# ============================================================
# CONTAINER SETUP
# ============================================================

# Server pack URL; required on first container start, unnecessary after installation
SERVER_PACK_URL=https://example.file/server.zip

# Must be true to start the server (accept Minecraft EULA)
EULA=false

# ============================================================
# JVM SETTINGS
# ============================================================

# Maximum RAM allocated to JVM
JVM_XMX=16G

# Initial RAM allocated on server start
JVM_XMS=8G

# ============================================================
# SERVER STARTUP
# ============================================================

# Name of the script used to start the server
START_SCRIPT=start.sh

# Path on host for server data (Docker bind mount)
HOST_SERVER_PATH=/opt/mc-server

# ============================================================
# SERVER PROPERTIES
# ============================================================

# Message shown in the server list
MC_MOTD="Message of a day"

# Maximum number of players allowed on the server at the same time
MC_MAX_PLAYERS=4

# Difficulty: peaceful | easy | normal | hard
MC_DIFFICULTY=normal

# Default gamemode: survival | creative | adventure | spectator
MC_GAMEMODE=survival

# Enable hardcore mode (one life, ban on death)
MC_HARDCORE=false

# Allow player vs player combat
MC_PVP=true

# World seed (leave empty for random)
MC_LEVEL_SEED=

# Name of the world folder
MC_LEVEL_NAME=world

# World type: DEFAULT | FLAT | LARGEBIOMES | AMPLIFIED | Modded one
MC_LEVEL_TYPE=DEFAULT

# Chunk render distance (in chunks, 3–32); affects performance
MC_VIEW_DISTANCE=10

# Block radius around spawn protected from non-ops (0 = disabled)
MC_SPAWN_PROTECTION=16

# Authenticate players with Mojang servers; set false for offline/cracked
MC_ONLINE_MODE=true

# Enable whitelist (only listed players can join)
MC_WHITELIST=false

# ============================================================
# RCON (Remote Console)
# ============================================================

# Enable RCON remote console access
MC_ENABLE_RCON=false

# RCON password — REQUIRED if MC_ENABLE_RCON=true
MC_RCON_PASSWORD=
